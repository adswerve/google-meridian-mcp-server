FROM python:3.12-slim
ENV PYTHONUNBUFFERED=1 PIP_NO_CACHE_DIR=1
WORKDIR /app
COPY pyproject.toml README.md ./
COPY src ./src
# jax[cuda12] ships self-contained CUDA runtime wheels; Cloud Run L4 supplies the
# GPU driver, so no nvidia/cuda base image is needed.
RUN pip install --upgrade pip && pip install "." "jax[cuda12]>=0.4"
ENV MERIDIAN_BACKEND=jax
ENTRYPOINT ["python", "-m", "google_meridian_mcp_server.execution.worker"]
