{
  "$schema": "https://gofastmcp.com/public/schemas/fastmcp.json/v1.json",
  "source": {
    "type": "filesystem",
    "path": "./src/google_meridian_mcp_server/server.py",
    "entrypoint": "mcp"
  },
  "environment": {
    "type": "uv",
    "python": ">=3.12,<3.15",
    "project": ".",
    "editable": [
      "."
    ],
    "dependencies": [
      "google-meridian[schema]==1.7.0"
    ]
  },
  "deployment": {
    "transport": "stdio",
    "log_level": "INFO"
  }
}