# Copy this file to .env in the repository root.

# ── Transport ──────────────────────────────────────────────────────
# MCP transport mode: "streamable-http" (default) or "stdio"
MCP_TRANSPORT=streamable-http

# Local bind address and port for streamable HTTP.
# Cloud Run injects PORT automatically; keep MCP_HOST at 0.0.0.0 in containers.
MCP_HOST=127.0.0.1
MCP_PORT=8000

# ── Persistence backend ───────────────────────────────────────────
# "local" or "gcs"
PERSISTENCE_BACKEND=local

# ── Local backend settings ────────────────────────────────────────
# Root directory containing Meridian model files (.binpb or .pkl)
# Nested layouts such as ./models/geo-revenue/model.binpb are supported.
LOCAL_MODELS_ROOT=./models

# ── GCS backend settings ─────────────────────────────────────────
# GCS_BUCKET=my-project.appspot.com
# GCS_MODELS_PREFIX=models

# ── Cache settings ────────────────────────────────────────────────
# Local directory for materialised remote model files
MODEL_CACHE_ROOT=/tmp/mmm-models

# How long (seconds) model catalog discovery results are cached
DISCOVERY_TTL_SECONDS=7200

# Enable transparent internal caching of repeated analysis results
RESULT_CACHE_ENABLED=true

# TTL (seconds) for cached analysis results (leave empty for no expiry)
# RESULT_CACHE_TTL_SECONDS=3600

# Optimization module (Phase 1: local executor only)
REGISTRY_BACKEND=local
OPTIMIZATION_RUNS_ROOT=./optimizations
OPTIMIZATION_ALLOWED_TIERS=local
OPTIMIZATION_DEFAULT_TIER=auto
OPTIMIZATION_MAX_PARALLEL=2
OPTIMIZATION_SIZE_THRESHOLDS=1000000,100000000
OPTIMIZATION_BACKEND_LOCAL=tensorflow
OPTIMIZATION_HEARTBEAT_STALE_SECONDS=60
